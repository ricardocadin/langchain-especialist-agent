# OpenAI (default provider)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-5-nano

# Postgres / pgvector
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/agent_search
PG_VECTOR_COLLECTION_NAME=earnings_release

# Document to ingest
PDF_PATH=./earnings_press_release.pdf
